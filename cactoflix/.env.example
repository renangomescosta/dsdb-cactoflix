# Copie para .env em cada servidor e preencha com os IPs reais dos nós.

# --- Usado no servidor de cada banco (docker-compose.database.yaml) ---
# Nome/identificador deste nó específico: banco1, banco2, banco3, banco4 ou banco5
BANCO_NAME=banco1

# --- Usado no servidor de cada app (docker-compose.app.yaml) ---
# e no servidor que rodar o mongo-setup uma única vez (docker-compose.mongo-setup.yaml)
BANCO1_IP=192.168.0.101
BANCO2_IP=192.168.0.102
BANCO3_IP=192.168.0.103
BANCO4_IP=192.168.0.104
BANCO5_IP=192.168.0.105

# --- Usado no servidor do load balancer (docker-compose.loadBalancer.yaml) ---
APP1_IP=192.168.0.111
APP2_IP=192.168.0.112
APP3_IP=192.168.0.113
